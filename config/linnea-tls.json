{
  "log": "linnea.log",
  "timeout": 60,
  "servers": [
    {
      "host": "0.0.0.0", "port": 443, "hostname": "linnea.amberbio.com",
      "cert": "/home/linnea/certs/linnea.amberbio.com/fullchain.pem", "key": "/home/linnea/certs/linnea.amberbio.com/privkey.pem",
      "locations": [
        { "prefix": "/", "root": "/home/linnea/www/linnea" }
      ]
    },
    {
      "host": "0.0.0.0", "port": 443, "hostname": "linnea2.amberbio.com",
      "cert": "/home/linnea/certs/linnea2.amberbio.com/fullchain.pem", "key": "/home/linnea/certs/linnea2.amberbio.com/privkey.pem",
      "locations": [
        { "prefix": "/", "root": "/home/linnea/www/linnea2" }
      ]
    },
    {
      "host": "0.0.0.0", "port": 80, "hostname": "linnea.amberbio.com",
      "locations": [
        { "prefix": "/.well-known/acme-challenge", "root": "/home/linnea/acme" },
        { "prefix": "/", "redirect": "https://linnea.amberbio.com" }
      ]
    },
    {
      "host": "0.0.0.0", "port": 80, "hostname": "linnea2.amberbio.com",
      "locations": [
        { "prefix": "/.well-known/acme-challenge", "root": "/home/linnea/acme" },
        { "prefix": "/", "redirect": "https://linnea2.amberbio.com" }
      ]
    }
  ]
}
